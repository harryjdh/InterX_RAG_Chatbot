# LLM API
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=http://your-llm-endpoint/v1
LLM_MODEL_NAME=Qwen/Qwen3-Next-80B-A3B-Instruct-FP8

# Embedding API
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=http://your-embedding-endpoint/v1
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIM=2560

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=change-me-in-production

# Redis (분산 Rate Limiter / 서킷 브레이커 — 미설정 시 인메모리 폴백)
REDIS_URL=

# RAG
TOP_K=5

# 요청 처리
MAX_QUERY_LEN=500
REQUEST_TIMEOUT=180.0

# DB 커넥션 풀 (WORKERS × DB_POOL_MAX_SIZE ≤ PostgreSQL max_connections)
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# API 클라이언트 타임아웃 (초)
LLM_TIMEOUT=120.0
EMBEDDING_TIMEOUT=30.0

# 헬스체크 타임아웃 (초)
HEALTH_DB_TIMEOUT=5.0
HEALTH_EMBEDDING_TIMEOUT=10.0
HEALTH_LLM_TIMEOUT=10.0

# 로깅 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# OpenAPI 문서 노출 여부 (프로덕션: False, 개발: True)
DOCS_ENABLED=True

# CORS: 허용할 오리진 (JSON 배열 형식, 기본값: 전체 허용)
# CORS_ORIGINS=["https://your-frontend.com"]

# Prometheus /metrics 엔드포인트 보호용 Bearer 토큰 (미설정 시 인증 없음)
# METRICS_TOKEN=your-secure-token

# Rate Limiting: IP당 요청 상한 (SlowAPI limits 형식: "N/period")
RATE_LIMIT=20/minute

# Uvicorn 워커 수 (Docker) — DB_POOL_MAX_SIZE × WORKERS ≤ PostgreSQL max_connections
WORKERS=4
